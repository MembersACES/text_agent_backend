# =============================================================================
# Backend environment variables (copy to .env and fill in real values)
# =============================================================================

# --- External task API (optional; scripts / n8n without Google ID token) ---
# When set, send header: X-Tasks-API-Key: <same value> on /api/tasks* and GET /api/users
# TASKS_EXTERNAL_API_KEY=
# Email used for task history / assigned_by when using the key (must be a valid mailbox you control)
# TASKS_EXTERNAL_ACTOR_EMAIL=automation@yourdomain.com

# --- Auth (Google OAuth / Next.js) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# --- Backend API key (used when frontend calls backend without Google token) ---
# BACKEND_API_KEY=test-key

# --- Google Sheets / Drive (service account) ---
# Path to service account JSON key file, or use SERVICE_ACCOUNT_JSON (inline JSON)
# SERVICE_ACCOUNT_FILE=service-account-key.json
# SERVICE_ACCOUNT_JSON=

# --- One Month Savings (invoice logging sheet + Drive folder) ---
# ONE_MONTH_SAVINGS_SHEET_ID=           # Google Sheet ID for 1st Month Savings invoice log
# ONE_MONTH_SAVINGS_SHEET_NAME=Sheet1
# ONE_MONTH_SAVINGS_DRIVE_FOLDER_ID=   # Folder ID for invoice PDFs AND solar cleaning quotes (default parent)
#                                      # MUST be inside a Google Shared Drive (Team Drive): service accounts
#                                      # have no My Drive quota. Add the service account to that Shared Drive.

# --- Resources page: videos (Drive folder listing via service account) ---
# Folder must be shared with the same service account as Sheets/Drive above.
# RESOURCES_VIDEOS_FOLDER_ID=1VmTut-4mztUiz95g2BqnZTMoeCVMhsb9

# --- Solar cleaning quote ---
# Template and T&C Google Doc IDs are hardcoded in tools/solar_cleaning_quote.py
# Quotes are created under ONE_MONTH_SAVINGS_DRIVE_FOLDER_ID/Solar Cleaning Quotes/ unless client_folder_url
# points elsewhere — that URL must also be a folder inside a Shared Drive for the same reason.

# --- Solar cleaning signed offers (Dashboard Quotes Signed sheet) ---
# Defaults match production; override if the sheet or tab moves.
# SOLAR_SIGNED_QUOTES_SHEET_ID=1WiLksDOwrQkEwVhF25F_RQ1G0zxF5VHiu9lAxQhQox4
# SOLAR_SIGNED_QUOTES_TAB=Dashboard Quotes Signed

# --- One Month Savings CALCULATION (Member ACES Data sheet) ---
# Google Sheet ID for "Member ACES Data" – must be shared with the same service account.
# Used to read invoice data by NMI/MRIN and period to calculate 1-month savings.
# MEMBER_ACES_DATA_SHEET_ID=1ozwxJjqBQE3fJeMHmsXzPFCsekupwXZ3A7F0jstOfVw

# --- Optional n8n fallback for one-month-savings ---
# USE_N8N_FALLBACK=false

# --- Database ---
# DB_TYPE=sqlite
# DATABASE_URL=
# SQLITE_DB_NAME=aces-task-db.sqlite3

# --- Airtable (direct link for business/utility data; optional, falls back to n8n if unset) ---
# Personal access token with data.records:read, data.records:write, schema.bases:read
# AIRTABLE_API_KEY=
# Base ID for "Member ACES Data" (from Airtable URL or run: python airtable_inspect.py)
# AIRTABLE_BASE_ID=appG1WoHcJt10iO5K
# When set, get-business-info and data-request use Airtable instead of n8n for LOA + utilities.
# USE_AIRTABLE_DIRECT=true

# --- Other ---
# OPENAI_API_KEY=
# FILE_IDS_SHEET_ID=
# FILE_IDS_SHEET_NAME=
# BASE1_LANDING_SHEET_ID=
# BASE1_LANDING_SHEET_NAME=
# TESTIMONIAL_STORAGE_FOLDER_ID=

# --- Testimonial document template (Google Doc) ---
# Google Doc ID for the testimonial template (e.g. 1-page savings confirmation).
# The Doc must be shared with the same Google account used by the n8n "testimonial-generation"
# workflow. Use placeholders like {{business_name}}, {{monthly_savings}}.
# TESTIMONIAL_TEMPLATE_DOC_ID=1sFquN7bpWskP8NPNwSGFS7T82fCp2f1yG0weVl_Vkxw

# GCS_BUCKET_NAME=local
# DISABLE_DB_SYNC=false

# --- Autonomous follow-up sequences (Base 2: C&I gas & C&I electricity comparison) ---
# sequence_type: gas_base2_followup_v1 | ci_electricity_base2_followup_v1 (same cadence; branch in n8n on context.utility_lane)
# n8n webhooks (email / SMS). Leave unset to log placeholders only.
# N8N_AUTONOMOUS_EMAIL_WEBHOOK_URL=
# N8N_AUTONOMOUS_SMS_WEBHOOK_URL=
# RETELL_API_BASE_URL=https://api.retellai.com
# RETELL_API_KEY=
# Optional: APScheduler tick to execute due steps (set true in dev if you want auto-send)
# AUTONOMOUS_SCHEDULER_ENABLED=false
# AUTONOMOUS_SCHEDULER_INTERVAL_SECONDS=60
# Shared secret for POST /api/autonomous/sequences/inbound (n8n / Retell callbacks). If unset, inbound is open (dev only).
# AUTONOMOUS_INBOUND_SECRET=
